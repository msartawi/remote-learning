DOMAIN=femt.llc
DOMAIN_WWW=www.femt.llc
LETSENCRYPT_EMAIL=admin@femt.llc
PUBLIC_IP=92.253.101.187

# Keycloak (set when AUTH_REQUIRED=true)
AUTH_REQUIRED=false
KEYCLOAK_ISSUER=
KEYCLOAK_JWKS_URL=
KEYCLOAK_AUDIENCE=femt-api
KEYCLOAK_BASE_URL=https://auth.femt.llc
KEYCLOAK_REALM=femt
KEYCLOAK_CLIENT_ID=femt-frontend
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=
KEYCLOAK_DB_PASSWORD=
SESSION_SECRET=change-me
COOKIE_DOMAIN=femt.llc
COOKIE_SECURE=true

# Host ports
HTTP_PORT=80
HTTPS_PORT=443

# Upstreams used by nginx reverse proxy
FRONTEND_UPSTREAM=http://frontend:80
BACKEND_UPSTREAM=http://backend:3001

# Frontend build-time config
VITE_API_BASE_URL=/api
VITE_KEYCLOAK_URL=https://auth.femt.llc
VITE_KEYCLOAK_REALM=femt
VITE_KEYCLOAK_CLIENT_ID=femt-frontend
